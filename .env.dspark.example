# Sanitized 2-node cluster template for DSpark on GB10 (TP=2 over RoCE).
# Copy to `.env` and fill in your own values. No real values are committed.

# RoCE fabric IP of the head node (rank 0 — hosts the rendezvous + OpenAI API).
MASTER_ADDR=<master-roce-ip>

# RoCE fabric IP of the worker node (rank 1 — --headless).
WORKER_HOST=<worker-roce-ip>

# RoCE HCA device name (e.g. the cabled QSFP RDMA NIC).
NCCL_IB_HCA=<roce-hca>

# RoCE v2 GID index for the QSFP IPv4 (typically 3 on DGX Spark).
NCCL_IB_GID_INDEX=3

# TCP rendezvous port the head listens on for NCCL init.
RDV_PORT=<rdv-port>

# HuggingFace cache dir holding the DeepSeek-V4-Flash-DSpark weights on each node.
HF_CACHE=<hf-cache-dir>
